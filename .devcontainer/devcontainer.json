{
  "name": "Elevate LMS",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:1-20-bookworm",
  // Persist .next/cache across container restarts so webpack / tsc incremental
  // builds reuse prior compilation artifacts.  The volume is named per-project
  // so multiple clones don't share a cache.
  "mounts": [
    "source=elevate-lms-next-cache,target=/workspaces/Elevate-lms/.next/cache,type=volume"
  ],
  "forwardPorts": [3000, 3001],
  "portsAttributes": {
    "3000": {
      "label": "Next.js LMS (port 3000)",
      "onAutoForward": "notify"
    },
    "3001": {
      "label": "Admin app (port 3001)",
      "onAutoForward": "notify"
    }
  },
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    }
  },
  // onCreateCommand — runs once when the container image is first built.
  // Install system deps (ffmpeg, chromium) that are not in the base image.
  "onCreateCommand": "sudo apt-get update && sudo apt-get install -y --no-install-recommends ffmpeg chromium python3 python3-pip libxml2-utils && sudo rm -rf /var/lib/apt/lists/*",
  // postCreateCommand — runs once after the workspace is created.
  // Activates pnpm via corepack, installs deps, and bootstraps .env.local once.
  "postCreateCommand": "bash -lc 'corepack enable && corepack prepare pnpm@10.28.2 --activate && pnpm install && bash .devcontainer/setup-env.sh'",
  // postStartCommand — runs on every container start.
  // Kept intentionally lightweight: only reassemble .env.local from secret
  // chunks if they are present (e.g. Codespaces secrets injected as files).
  // Dependency installation and media generation are one-time operations
  // handled in postCreateCommand.
  "postStartCommand": "bash -lc 'bash .devcontainer/setup-env.sh'",
  "remoteEnv": {
    "PUPPETEER_EXECUTABLE_PATH": "/usr/bin/chromium",
    "CHROMIUM_PATH": "/usr/bin/chromium",
    "NEXT_TELEMETRY_DISABLED": "1"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss",
        "ms-vscode.vscode-typescript-next",
        "eamodio.gitlens",
        "christian-kohler.path-intellisense",
        "github.copilot",
        "github.copilot-chat",
        "github.vscode-pull-request-github",
        "redhat.vscode-yaml",
        "yzhang.markdown-all-in-one",
        "ms-azuretools.vscode-docker",
        "mtxr.sqltools",
        "mtxr.sqltools-driver-pg"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.codeActionsOnSave": {
          "source.fixAll.eslint": "explicit"
        },
        "typescript.tsdk": "node_modules/typescript/lib",
        "typescript.enablePromptUseWorkspaceTsdk": true,
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    },
    "codespaces": {
      "openFiles": ["README.md"]
    }
  }
}
