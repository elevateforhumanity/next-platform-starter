{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "preserve",
    "strict": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "noImplicitAny": false,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "incremental": true,
    "tsBuildInfoFile": ".next/cache/tsbuildinfo.json",
    "noImplicitReturns": true,
    "noUncheckedIndexedAccess": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@/components/ui/label": [
        "./components/ui/label.tsx"
      ],
      "@/components/ui/input": [
        "./components/ui/input.tsx"
      ],
      "@/components/ui/badge": [
        "./components/ui/badge.tsx"
      ],
      "@/components/ui/button": [
        "./components/ui/button.tsx"
      ],
      "@/components/ui/card": [
        "./components/ui/card.tsx"
      ]
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "allowJs": true,
    "strictNullChecks": false,
    "skipDefaultLibCheck": true
  },
  "include": [
    "next-env.d.ts",
    "types/**/*.ts",
    "types/**/*.d.ts",
    "app/**/*.ts",
    "app/**/*.tsx",
    "components/ui/**/*.ts",
    "components/ui/**/*.tsx",
    "components/dashboard/**/*.ts",
    "components/dashboard/**/*.tsx",
    "components/lms/**/*.ts",
    "components/lms/**/*.tsx",
    "components/DoceboHeader.tsx",
    "components/GoogleAnalytics.tsx",
    "components/MOUStatusBadge.tsx",
    "components/SignaturePad.tsx",
    "components/StructuredData.tsx",
    "components/support/**/*.ts",
    "components/support/**/*.tsx",
    "lib/**/*.ts",
    "lib/**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "dist",
    "build",
    "coverage",
    ".turbo",
    "workers",
    "deployment-ready",
    "supabase/functions",
    ".archive",
    "_archived",
    "backend",
    "lib/new-ecosystem-services",
    "**/*-backup*",
    "**/*-old*",
    "**/*-new*",
    "**/*-redesign*",
    "app-backup-*",
    "tests",
    "__tests__",
    "e2e",
    "scripts",
    "tools",
    "*.test.ts",
    "*.test.tsx",
    "*.spec.ts",
    "*.spec.tsx",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx"
  ]
}
