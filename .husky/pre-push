#!/bin/sh
# Pre-push gate: enforces compile integrity and orphan JSX detection before any push.
# Catches errors locally instead of wasting CodeBuild cycles.

echo "🔒 Pre-push checks running..."

# 1. Redirect conflict + public route guards
echo "  → Checking redirect conflicts and public route guards..."
pnpm run build:lms:checks || {
  echo "❌ build:lms:checks failed. Fix conflicts before pushing."
  exit 1
}

# 2. TypeScript compile check
echo "  → TypeScript type check (baseline-aware)..."
if ! NODE_OPTIONS=--max-old-space-size=4096 node scripts/typecheck-baseline.mjs; then
  echo "❌ TypeScript: new errors detected. Fix before pushing."
  exit 1
fi
echo "  ✅ TypeScript: no new errors against baseline"

# 3. Orphan JSX detector — catch incomplete redirect stub conversions
echo "  → Checking for orphaned JSX in redirect stubs..."
DIRTY_FILES=$(python3 - << 'PYEOF'
import re, os, sys

app_dir = "app"
dirty = []

for root, dirs, files in os.walk(app_dir):
    dirs[:] = [d for d in dirs if d not in ["node_modules", ".next"]]
    for name in files:
        if name != "page.tsx":
            continue
        path = os.path.join(root, name)
        try:
            content = open(path).read()
        except Exception:
            continue
        m = re.search(
            r'export default function \w+\(\)[^{]*\{\s*permanentRedirect\([^)]+\);\s*\}',
            content
        )
        if m:
            after = content[m.end():]
            if after.strip():
                dirty.append(path)

for f in dirty:
    print(f)
PYEOF
)

if [ -n "$DIRTY_FILES" ]; then
  echo "❌ Orphaned JSX found after redirect stubs in:"
  echo "$DIRTY_FILES"
  echo "   Each file should contain ONLY the redirect — no return/JSX after the closing brace."
  exit 1
fi
echo "  ✅ Orphan JSX: clean"

# 4. ESLint — run only on files changed since the last pushed commit.
# Full repo lint runs in CI (CodeBuild). Local pre-push scopes to changed files
# to avoid OOM on the 1,300+ page codebase.
echo "  → ESLint (changed files only)..."

# Get files changed vs remote HEAD (or all staged if no remote ref yet)
REMOTE_REF=$(git rev-parse --verify origin/main 2>/dev/null || echo "")
if [ -n "$REMOTE_REF" ]; then
  CHANGED=$(git diff --name-only --diff-filter=d "$REMOTE_REF"..HEAD -- '*.ts' '*.tsx' | grep -v node_modules | grep -v '\.next' | tr '\n' ' ')
else
  CHANGED=$(git diff --name-only --diff-filter=d HEAD~1..HEAD -- '*.ts' '*.tsx' | grep -v node_modules | grep -v '\.next' | tr '\n' ' ')
fi

if [ -z "$CHANGED" ]; then
  echo "  ✅ ESLint: no TS/TSX files changed, skipping."
else
  # Filter out files in eslint-ignored directories (scripts/, _archived/, etc.)
  # to avoid the "File ignored" warning that fails --max-warnings=0
  LINTABLE=$(echo "$CHANGED" | tr ' ' '\n' | grep -v "^scripts/\|^_archived/\|^tools/\|^supabase/\|^tests/" | tr '\n' ' ')
  if [ -z "$LINTABLE" ]; then
    echo "  ✅ ESLint: only ignored files changed, skipping."
  else
    if ! NODE_OPTIONS='--max-old-space-size=4096' npx eslint $LINTABLE --max-warnings=0 2>&1; then
      echo "❌ ESLint: violations found in changed files. Fix before pushing."
      exit 1
    fi
    echo "  ✅ ESLint: clean"
  fi
fi

echo "✅ Pre-push checks passed. Pushing..."
