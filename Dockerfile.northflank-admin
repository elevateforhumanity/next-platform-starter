# Dockerfile.northflank-admin
#
# Builds apps/admin on Northflank (combined CI/CD). Mirrors aws/buildspec-admin.yml.
# Runtime layout matches Dockerfile.admin (custom server.js, ws, public assets).

FROM public.ecr.aws/docker/library/node:20-bookworm AS builder

RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 \
    build-essential \
    ca-certificates \
    libcairo2-dev \
    libpango1.0-dev \
    libjpeg-dev \
    libgif-dev \
    librsvg2-dev \
    && rm -rf /var/lib/apt/lists/*

ENV COREPACK_ENABLE_DOWNLOAD_PROMPT=0
RUN corepack enable && corepack prepare pnpm@10.28.2 --activate

WORKDIR /app

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY apps/admin/package.json apps/admin/package.json

RUN pnpm install --frozen-lockfile

COPY . .

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV NODE_OPTIONS=--max-old-space-size=8192
ENV BUILD_SCOPE=1
# Required at `next build` (overridden by Northflank secret group / build args when set)
ENV NEXT_PUBLIC_ADMIN_URL=https://admin.elevateforhumanity.org
ENV NEXT_PUBLIC_SITE_URL=https://admin.elevateforhumanity.org
ENV NEXT_PUBLIC_PUBLIC_SITE_URL=https://elevateforhumanity.org
ENV NEXT_PUBLIC_SUPABASE_URL=https://cuxzzpsyufcewtmicszk.supabase.co
ENV NEXT_PUBLIC_SUPABASE_ANON_KEY=build-placeholder
ENV SKIP_ENV_VALIDATION=true

RUN cd apps/admin && pnpm exec next build

# Bundle ws for runtime (avoid npm install in slim image — npm peer-resolve fails in CI)
RUN mkdir -p /export && cp -rL apps/admin/node_modules/ws /export/ws

# --- runtime (same as Dockerfile.admin) ---
FROM public.ecr.aws/docker/library/node:20-bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    fonts-liberation \
    && rm -rf /var/lib/apt/lists/*

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV HOSTNAME=0.0.0.0
ENV PORT=8080
ARG COMMIT_REF=dev
ENV COMMIT_REF=$COMMIT_REF

WORKDIR /app

RUN npm install --os=linux --cpu=x64 sharp@0.33.5 --no-save 2>/dev/null || \
    npm install sharp@0.33.5 --no-save

COPY --from=builder /app/apps/admin/.next/standalone ./
COPY --from=builder /app/apps/admin/.next/server ./apps/admin/.next/server
COPY --from=builder /app/apps/admin/.next/static ./apps/admin/.next/static
COPY --from=builder /app/apps/admin/.next/required-server-files.json ./apps/admin/.next/required-server-files.json
COPY --from=builder /app/public ./apps/admin/public
COPY --from=builder /app/apps/admin/server.js ./apps/admin/server.js
COPY --from=builder /export/ws ./apps/admin/node_modules/ws

RUN addgroup --gid 1001 nodejs && \
    adduser --uid 1001 --ingroup nodejs --disabled-password --gecos "" nextjs && \
    chown -R nextjs:nodejs /app

USER nextjs

EXPOSE 8080

CMD ["node", "apps/admin/server.js"]
