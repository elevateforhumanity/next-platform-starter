# onlyBuiltDependencies in package.json controls which packages run install
# scripts — enable-pre-post-scripts is superseded by that setting in pnpm 10.
# Northflank/Docker builds must use the public npm registry for public packages.
registry=https://registry.npmjs.org/
fetch-retries=3
fetch-retry-factor=2
fetch-retry-mintimeout=10000
fetch-retry-maxtimeout=60000
network-concurrency=16
