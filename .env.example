# ── OpenTelemetry (instrumentation.ts) ────────────────────────────────────────
# Leave blank to disable tracing (zero cost). Set to enable distributed traces.
# Compatible with any OTLP-capable backend: Grafana Cloud, Honeycomb, Datadog, etc.
#
# Example (Grafana Cloud):
#   OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-prod-us-east-0.grafana.net/otlp
#   OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic <base64(instanceId:apiKey)>
#
# Example (Honeycomb):
#   OTEL_EXPORTER_OTLP_ENDPOINT=https://api.honeycomb.io
#   OTEL_EXPORTER_OTLP_HEADERS=x-honeycomb-team=<api-key>
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_SERVICE_NAME=elevate-lms
