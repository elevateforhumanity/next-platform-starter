# Elevate for Humanity - Environment Variables Template
#
# PRODUCTION (Netlify):
#   Only 3 bootstrap vars go in Netlify Site Settings → Environment Variables:
#     NEXT_PUBLIC_SUPABASE_URL
#     NEXT_PUBLIC_SUPABASE_ANON_KEY
#     SUPABASE_SERVICE_ROLE_KEY
#   All other secrets live in the Supabase `app_secrets` table.
#   See: lib/secrets.ts, scripts/seed-app-secrets.sh
#
#   NEXT_PUBLIC_* vars needed at build time should use scope "Builds" in
#   Netlify dashboard so they aren't injected into Lambda functions.
#
# LOCAL DEVELOPMENT:
#   1. Copy: cp .env.example .env.local
#   2. Fill in all values
#   3. Never commit .env.local!
#   (Local dev reads process.env directly — app_secrets is a fallback.)

# =============================================================================
# REQUIRED - Core functionality won't work without these
# =============================================================================

# Database & Supabase
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_PROJECT_REF=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
POSTGRES_URL=
POSTGRES_PASSWORD=

# Authentication
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
# REQUIRED in all environments. Used for redirect targets in checkout and auth flows.
# Missing or wrong value causes checkout failure redirects to point at localhost.
# Production: https://yourdomain.com  Staging: https://staging.yourdomain.com
NEXT_PUBLIC_SITE_URL=https://www.elevateforhumanity.org

# Organization identity — used as fallbacks when platform_settings DB rows are absent.
# These are baked into the build; runtime values come from platform_settings table.
NEXT_PUBLIC_ORG_NAME=Elevate for Humanity
NEXT_PUBLIC_ORG_LEGAL_NAME=Elevate for Humanity Technical and Career Institute
NEXT_PUBLIC_SUPPORT_EMAIL=support@elevateforhumanity.org
NEXT_PUBLIC_SUPPORT_PHONE=(317) 314-3757
NEXT_PUBLIC_EMAIL_FROM_NAME=Elevate for Humanity
NEXT_PUBLIC_EMAIL_FROM_ADDRESS=noreply@elevateforhumanity.org
NEXT_PUBLIC_CERT_HOLDER=Elevate for Humanity
NEXT_PUBLIC_CANONICAL_DOMAIN=www.elevateforhumanity.org

# =============================================================================
# PAYMENTS - Required for payment processing
# =============================================================================

# Stripe Core
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe Store Webhook (for digital product fulfillment)
STRIPE_WEBHOOK_SECRET_STORE=

# Stripe Price IDs - Capital Readiness Products
STRIPE_PRICE_CR_GUIDE=price_xxx
STRIPE_PRICE_CR_ENTERPRISE=price_xxx

# =============================================================================
# FILE STORAGE - Required for digital product downloads (Cloudflare R2 / S3)
# =============================================================================
#
# Upload files to these paths in your bucket:
#   guides/capital-readiness-guide-v1.pdf
#   guides/tax-business-toolkit-v1.pdf
#   guides/grant-readiness-guide-v1.pdf
#   workbooks/capital-readiness-workbook-v1.pdf
#
# See lib/storage/file-storage.ts for full path mapping

# Cloudflare R2 (S3-compatible) - RECOMMENDED for private file storage
R2_ENDPOINT=https://xxx.r2.cloudflarestorage.com
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=elevate-media

# AWS S3 (alternative to R2)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=elevate-downloads

# =============================================================================
# LICENSING - Required for enterprise licensing system
# =============================================================================

# Licensing mode (production or development)
LICENSING_MODE=production
NEXT_PUBLIC_ADMIN_URL=https://admin.elevateforhumanity.org
NEXT_PUBLIC_LMS_URL=https://www.elevateforhumanity.org/lms
# Service role selector for split deployments/routing.
# Used by scripts/railway-quarantine-marketing-routes.mjs, lib/auth/require-role.ts,
# and ECS task definitions (aws/ecs-task-*.json).
# Valid values: lms | admin | all. If unset, scripts that read it default to all.
SERVICE_ROLE=lms

# Cron secret for queue processing
CRON_SECRET=
JOB_PROCESSOR_TOKEN=
PARTNER_WEBHOOK_SECRET=
EXTERNAL_VIDEO_WEBHOOK_SECRET=
APPLICATION_INTAKE_ALLOWED_ORIGINS=
APPLICATION_INTAKE_IDEMPOTENCY_TTL_SECONDS=86400
TURNSTILE_SECRET_KEY=

# Upstash Redis (for fulfillment queue)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Sezzle (Buy Now Pay Later - 4 interest-free payments)
SEZZLE_PUBLIC_KEY=
SEZZLE_PRIVATE_KEY=
SEZZLE_ENVIRONMENT=sandbox
SEZZLE_WEBHOOK_SECRET=
NEXT_PUBLIC_SEZZLE_PUBLIC_KEY=
NEXT_PUBLIC_SEZZLE_MERCHANT_ID=
NEXT_PUBLIC_SEZZLE_ENVIRONMENT=sandbox

# NHA — National Healthcareer Association
# Account number assigned to Elevate for Humanity (account: 412957)
# Used for exam ordering, proctoring, and partner routing for CPT/CCMA/CBCS programs.
NHA_ACCOUNT_NUMBER=
NHA_PORTAL_URL=https://www.nhanow.com/

# Affirm (Buy Now Pay Later)
# Get keys from https://affirm.com/business → Dashboard → API Keys
# Affirm BNPL
# AFFIRM_PUBLIC_KEY and NEXT_PUBLIC_AFFIRM_PUBLIC_KEY must be the same value.
# AFFIRM_PRIVATE_KEY is the secret key — never expose client-side.
# Set AFFIRM_ENVIRONMENT=sandbox for testing, production for live.
# AFFIRM_WEBHOOK_SECRET: set in Affirm merchant dashboard, sent as x-affirm-webhook-secret header.
# Webhook URL: https://www.elevateforhumanity.org/api/affirm/webhook
AFFIRM_PUBLIC_KEY=
AFFIRM_PRIVATE_KEY=
NEXT_PUBLIC_AFFIRM_PUBLIC_KEY=
AFFIRM_BASE_URL=https://api.affirm.com
AFFIRM_ENVIRONMENT=production
AFFIRM_WEBHOOK_SECRET=

