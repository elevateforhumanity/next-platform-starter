{
  "family": "elevate-admin",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "4096",
  "memory": "16384",
  "executionRoleArn": "arn:aws:iam::954718262498:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::954718262498:role/ecsTaskRole",
  "containerDefinitions": [
    {
      "name": "elevate-admin",
      "image": "954718262498.dkr.ecr.us-east-1.amazonaws.com/elevate-admin:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "CHROMIUM_PATH",
          "value": "/usr/bin/chromium"
        },
        {
          "name": "HOSTNAME",
          "value": "0.0.0.0"
        },
        {
          "name": "NEXT_PUBLIC_ADMIN_URL",
          "value": "https://admin.elevateforhumanity.org"
        },
        {
          "name": "NEXT_PUBLIC_CANONICAL_DOMAIN",
          "value": "www.elevateforhumanity.org"
        },
        {
          "name": "NEXT_PUBLIC_CERT_HOLDER",
          "value": "Elevate for Humanity"
        },
        {
          "name": "NEXT_PUBLIC_EMAIL_FROM_ADDRESS",
          "value": "noreply@elevateforhumanity.org"
        },
        {
          "name": "NEXT_PUBLIC_EMAIL_FROM_NAME",
          "value": "Elevate for Humanity"
        },
        {
          "name": "NEXT_PUBLIC_ORG_LEGAL_NAME",
          "value": "Elevate for Humanity Technical and Career Institute"
        },
        {
          "name": "NEXT_PUBLIC_ORG_NAME",
          "value": "Elevate for Humanity"
        },
        {
          "name": "NEXT_PUBLIC_SITE_URL",
          "value": "https://admin.elevateforhumanity.org"
        },
        {
          "name": "NEXT_PUBLIC_PUBLIC_SITE_URL",
          "value": "https://www.elevateforhumanity.org"
        },
        {
          "name": "NEXT_PUBLIC_SUPPORT_EMAIL",
          "value": "support@elevateforhumanity.org"
        },
        {
          "name": "NEXT_PUBLIC_SUPPORT_PHONE",
          "value": "(317) 314-3757"
        },
        {
          "name": "NEXT_TELEMETRY_DISABLED",
          "value": "1"
        },
        {
          "name": "NODE_ENV",
          "value": "production"
        },
        {
          "name": "OTEL_EXPORTER_OTLP_ENDPOINT",
          "value": ""
        },
        {
          "name": "OTEL_EXPORTER_OTLP_HEADERS",
          "value": ""
        },
        {
          "name": "OTEL_SERVICE_NAME",
          "value": "elevate-admin"
        },
        {
          "name": "PORT",
          "value": "3000"
        },
        {
          "name": "PUPPETEER_EXECUTABLE_PATH",
          "value": "/usr/bin/chromium"
        },
        {
          "name": "SERVICE_ROLE",
          "value": "admin"
        },
        {
          "name": "SUPABASE_PROJECT_REF",
          "value": "cuxzzpsyufcewtmicszk"
        },
        {
          "name": "NODE_OPTIONS",
          "value": "--max-old-space-size=4096"
        }
      ],
      "secrets": [
        {
          "name": "NEXT_PUBLIC_SUPABASE_URL",
          "valueFrom": "arn:aws:ssm:us-east-1:954718262498:parameter/elevate/NEXT_PUBLIC_SUPABASE_URL"
        },
        {
          "name": "NEXT_PUBLIC_SUPABASE_ANON_KEY",
          "valueFrom": "arn:aws:ssm:us-east-1:954718262498:parameter/elevate/NEXT_PUBLIC_SUPABASE_ANON_KEY"
        },
        {
          "name": "SUPABASE_SERVICE_ROLE_KEY",
          "valueFrom": "arn:aws:ssm:us-east-1:954718262498:parameter/elevate/SUPABASE_SERVICE_ROLE_KEY"
        },
        {
          "name": "STRIPE_SECRET_KEY",
          "valueFrom": "arn:aws:ssm:us-east-1:954718262498:parameter/elevate/STRIPE_SECRET_KEY"
        },
        {
          "name": "STRIPE_WEBHOOK_SECRET",
          "valueFrom": "arn:aws:ssm:us-east-1:954718262498:parameter/elevate/STRIPE_WEBHOOK_SECRET"
        },
        {
          "name": "NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY",
          "valueFrom": "arn:aws:ssm:us-east-1:954718262498:parameter/elevate/NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY"
        },
        {
          "name": "OPENAI_API_KEY",
          "valueFrom": "arn:aws:ssm:us-east-1:954718262498:parameter/elevate/OPENAI_API_KEY"
        },
        {
          "name": "ANTHROPIC_API_KEY",
          "valueFrom": "arn:aws:ssm:us-east-1:954718262498:parameter/elevate/ANTHROPIC_API_KEY"
        },
        {
          "name": "SENDGRID_API_KEY",
          "valueFrom": "arn:aws:ssm:us-east-1:954718262498:parameter/elevate/SENDGRID_API_KEY"
        },
        {
          "name": "CRON_SECRET",
          "valueFrom": "arn:aws:ssm:us-east-1:954718262498:parameter/elevate/CRON_SECRET"
        },
        {
          "name": "UPSTASH_REDIS_REST_URL",
          "valueFrom": "arn:aws:ssm:us-east-1:954718262498:parameter/elevate/UPSTASH_REDIS_REST_URL"
        },
        {
          "name": "UPSTASH_REDIS_REST_TOKEN",
          "valueFrom": "arn:aws:ssm:us-east-1:954718262498:parameter/elevate/UPSTASH_REDIS_REST_TOKEN"
        },
        {
          "name": "NEXTAUTH_SECRET",
          "valueFrom": "arn:aws:ssm:us-east-1:954718262498:parameter/elevate/NEXTAUTH_SECRET"
        },
        {
          "name": "GITHUB_TOKEN",
          "valueFrom": "arn:aws:ssm:us-east-1:954718262498:parameter/elevate/GITHUB_TOKEN"
        },
        {
          "name": "SENDGRID_FROM",
          "valueFrom": "arn:aws:ssm:us-east-1:954718262498:parameter/elevate/SENDGRID_FROM"
        },
        {
          "name": "SESSION_SECRET",
          "valueFrom": "arn:aws:ssm:us-east-1:954718262498:parameter/elevate/SESSION_SECRET"
        },
        {
          "name": "STRIPE_WEBHOOK_SECRET_BARBER",
          "valueFrom": "arn:aws:ssm:us-east-1:954718262498:parameter/elevate/STRIPE_WEBHOOK_SECRET_BARBER"
        },
        {
          "name": "GEMINI_API_KEY",
          "valueFrom": "arn:aws:ssm:us-east-1:954718262498:parameter/elevate/GEMINI_API_KEY"
        },
        {
          "name": "GROQ_API_KEY",
          "valueFrom": "arn:aws:ssm:us-east-1:954718262498:parameter/elevate/GROQ_API_KEY"
        },
        {
          "name": "SENTRY_DSN",
          "valueFrom": "arn:aws:ssm:us-east-1:954718262498:parameter/elevate/SENTRY_DSN"
        },
        {
          "name": "NEXT_PUBLIC_SENTRY_DSN",
          "valueFrom": "arn:aws:ssm:us-east-1:954718262498:parameter/elevate/NEXT_PUBLIC_SENTRY_DSN"
        },
        {
          "name": "SUPABASE_URL",
          "valueFrom": "arn:aws:ssm:us-east-1:954718262498:parameter/elevate/SUPABASE_URL"
        },
        {
          "name": "STUDIO_SHELL_WS_URL",
          "valueFrom": "arn:aws:ssm:us-east-1:954718262498:parameter/elevate/STUDIO_SHELL_WS_URL"
        },
        {
          "name": "STUDIO_SHELL_SECRET",
          "valueFrom": "arn:aws:ssm:us-east-1:954718262498:parameter/elevate/STUDIO_SHELL_SECRET"
        },
        {
          "name": "GITHUB_REPO",
          "valueFrom": "arn:aws:ssm:us-east-1:954718262498:parameter/elevate/GITHUB_REPO"
        },
        {
          "name": "DEVSTUDIO_DEVCONTAINER_MODE",
          "valueFrom": "arn:aws:ssm:us-east-1:954718262498:parameter/elevate/DEVSTUDIO_DEVCONTAINER_MODE"
        },
        {
          "name": "GITHUB_BRANCH",
          "value": "main"
        },
        {
          "name": "INTERNAL_API_KEY",
          "valueFrom": "arn:aws:ssm:us-east-1:954718262498:parameter/elevate/INTERNAL_API_KEY"
        },
        {
          "name": "REDIS_URL",
          "valueFrom": "arn:aws:ssm:us-east-1:954718262498:parameter/elevate/REDIS_URL"
        },
        {
          "name": "STUDIO_SHELL_WS_URL_PUBLIC",
          "valueFrom": "arn:aws:ssm:us-east-1:954718262498:parameter/elevate/STUDIO_SHELL_WS_URL_PUBLIC"
        },
        {
          "name": "STUDIO_TOKEN_SECRET",
          "valueFrom": "arn:aws:ssm:us-east-1:954718262498:parameter/elevate/STUDIO_TOKEN_SECRET"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/elevate-admin",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "curl -f http://localhost:3000/api/health || exit 1"
        ],
        "interval": 30,
        "timeout": 10,
        "retries": 3,
        "startPeriod": 60
      },
      "ulimits": [
        {
          "name": "nofile",
          "softLimit": 65536,
          "hardLimit": 65536
        }
      ],
      "memory": 6144,
      "memoryReservation": 3072
    }
  ]
}
