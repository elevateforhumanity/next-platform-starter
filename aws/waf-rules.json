{
  "WebACL": {
    "Name": "elevate-waf",
    "ARN": "arn:aws:wafv2:us-east-1:954718262498:regional/webacl/elevate-waf/8f0fa52a-2295-4727-a729-410654835003",
    "Scope": "REGIONAL",
    "DefaultAction": "Allow",
    "AssociatedResources": [
      "arn:aws:elasticloadbalancing:us-east-1:954718262498:loadbalancer/app/elevate-lms-alb/fedd865eb3bbce05",
      "arn:aws:elasticloadbalancing:us-east-1:954718262498:loadbalancer/app/elevate-admin-alb/6635cbdf07b67011"
    ]
  },
  "IPSets": {
    "elevate-blocked-ips": {
      "ARN": "arn:aws:wafv2:us-east-1:954718262498:regional/ipset/elevate-blocked-ips/7de84536-adcc-40d0-bb9d-4b5d40ba1c53",
      "Addresses": [
        "18.206.28.23/32"
      ],
      "Notes": "Clone/scraper IPs. Add new IPs here and run aws/scripts/update-blocked-ips.sh"
    }
  },
  "Rules": [
    {
      "Priority": 0,
      "Name": "AWSManagedRulesAmazonIpReputationList",
      "Type": "ManagedRuleGroup",
      "Vendor": "AWS",
      "Action": "Block (managed)",
      "Description": "AWS-maintained list of known malicious IPs, botnets, and scanners"
    },
    {
      "Priority": 1,
      "Name": "RateLimitPerIP",
      "Type": "RateBased",
      "Action": "Block",
      "Limit": 500,
      "Window": "5 minutes",
      "AggregateKey": "IP",
      "Description": "Blocks IPs exceeding 500 requests per 5-minute window"
    },
    {
      "Priority": 2,
      "Name": "BlockKnownScrapers",
      "Type": "ByteMatch",
      "Action": "Block",
      "Field": "user-agent",
      "Patterns": [
        "HTTrack",
        "wget",
        "scrapy",
        "python-requests",
        "go-http-client",
        "masscan",
        "zgrab",
        "httrack"
      ],
      "Description": "Blocks known site-cloning and scraping tools by user-agent"
    },
    {
      "Priority": 3,
      "Name": "BlockCloneIP",
      "Type": "IPSetReference",
      "Action": "Block",
      "IPSet": "elevate-blocked-ips",
      "Description": "Explicit IP block list — clone sites, abusers, DMCA violators"
    }
  ],
  "Management": {
    "AddBlockedIP": "aws/scripts/update-blocked-ips.sh NEW.IP.HERE/32",
    "Console": "https://console.aws.amazon.com/wafv2/homev2/web-acls/elevate-waf/overview?region=us-east-1",
    "Metrics": "CloudWatch > elevate-waf namespace"
  }
}
